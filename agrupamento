    print(f"IMC médio: {linha['IMC']:.1f}")


# ==========================================================
# INTERPRETAÇÃO DOS CLUSTERS
# ==========================================================

def interpretar_clusters(dados, coluna_cluster):

    perfis = dados.groupby(
        coluna_cluster
    )[atributos].mean()

    for cluster, linha in perfis.iterrows():

        print("=" * 60)

        if cluster == -1:
            print("Grupo -1: possíveis outliers")
        else:
            print(f"Grupo {cluster}")

        interpretacao = []

        if linha["Idade"] >= 50:
            interpretacao.append("clientes mais velhos")
        elif linha["Idade"] <= 30:
            interpretacao.append("clientes mais jovens")

        if linha["TreinosSemana"] >= 5:
            interpretacao.append("alta frequência de treino")
        elif linha["TreinosSemana"] <= 1:
            interpretacao.append("baixa frequência de treino")

        if linha["ConsumoAgua"] >= 3:
            interpretacao.append("boa hidratação")
        elif linha["ConsumoAgua"] <= 2:
            interpretacao.append("hidratação insuficiente")

        if linha["HorasSono"] >= 7:
            interpretacao.append("sono adequado")
        elif linha["HorasSono"] <= 5:
            interpretacao.append("poucas horas de sono")

        if linha["IMC"] >= 30:
            interpretacao.append("IMC elevado")
        elif linha["IMC"] <= 24:
            interpretacao.append("IMC dentro da faixa saudável")

        print("Perfil:", ", ".join(interpretacao))


print("\nINTERPRETAÇÃO K-MEANS")
interpretar_clusters(dados, "Cluster_KMeans")

print("\nINTERPRETAÇÃO AGNES")
interpretar_clusters(dados, "Cluster_AGNES")

print("\nINTERPRETAÇÃO DBSCAN")
interpretar_clusters(dados, "Cluster_DBSCAN")
