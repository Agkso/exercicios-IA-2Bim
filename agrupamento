# ==========================================================
# PERFIL DBSCAN
# ==========================================================

perfil_dbscan = dados.groupby(
    "Cluster_DBSCAN"
)[atributos].mean()

print(perfil_dbscan)

for cluster, linha in perfil_dbscan.iterrows():

    if cluster == -1:
        nome = "Ruído / Outliers"
    else:
        nome = f"Cluster {cluster}"

    print(f"\n{nome} - DBSCAN")

    print(f"Idade média: {linha['Idade']:.1f}")
